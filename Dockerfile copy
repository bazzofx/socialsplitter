# Stage 1: Development
FROM node:22.14.0-bullseye-slim AS dev

# Set working directory
WORKDIR /app

# Install build tools for native modules (needed for Tailwind)
RUN apt-get update && apt-get install -y python3 g++ make git curl \
    && rm -rf /var/lib/apt/lists/*

# Copy only package files for caching
COPY package*.json ./

# Install dependencies fresh
RUN npm install

# Copy the rest of the source code
COPY . .

# Expose dev port
EXPOSE 3099

# Start dev server using npx tsx (handles Node 22 ESM properly)
CMD ["npx", "run", "dev"]